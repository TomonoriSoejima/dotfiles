# Copy this file to ~/.env and fill in your actual API keys
# Never commit ~/.env to git!

export EC_API_KEY="your_elastic_cloud_api_key_here"
export ELASTIC_ECE_KEY="your_ece_key_here"
export ELASTIC_ECE_GOV_KEY="your_gov_key_here"
export OPENAI_API_KEY="your_openai_key_here"

# Elastic Cloud user-scoped API key (from cloud.elastic.co/account/keys)
export ELASTIC_CLOUD_API_KEY="your_cloud_api_key_here"

# Personal test cluster (used by estest() to test ES API calls)
export ELASTIC_TEST_URL="https://your-deployment.es.region.cloud.es.io"
export ELASTIC_TEST_API_KEY="your_es_api_key_encoded_here"
