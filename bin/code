#!/bin/bash
# Wrapper for 'code' command that auto-sets up Copilot instructions in ticket folders

# If we're in /Users/surfer/tickets/[ticket-folder], auto-setup
CURRENT_DIR=$(pwd)
if [[ "$CURRENT_DIR" == /Users/surfer/tickets/0* ]]; then
    # We're in a ticket folder, ensure .github/copilot-instructions.md exists
    if [ ! -f ".github/copilot-instructions.md" ]; then
        mkdir -p .github
        cp /Users/surfer/tickets/.github/copilot-instructions.md .github/ 2>/dev/null
        echo "✓ Copilot menu enabled for this ticket"
    fi
fi

# Run the actual VS Code command
/opt/homebrew/bin/code "$@"
